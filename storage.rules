rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helpers ──
    function isAuth() { return request.auth != null; }
    function getUserData() { return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data; }
    function isAdminRole() { return isAuth() && ("admin" in getUserData().roles || getUserData().role == "admin"); }
    function isReferee() { return isAuth() && ("referee" in getUserData().roles || getUserData().role == "referee"); }
    function isOrganizer() { return isAuth() && ("organizer" in getUserData().roles || getUserData().role == "organizer"); }

    // ── Conteúdo público — leitura livre, escrita apenas admin ──
    match /logos/{file}            { allow read: if true; allow write: if isAdminRole(); }
    match /banners/{file}          { allow read: if true; allow write: if isAdminRole(); }
    match /eventos/{path=**}       { allow read: if true; allow write: if isAdminRole(); }
    match /noticias/{file}         { allow read: if true; allow write: if isAdminRole(); }
    match /galeria/{file}          { allow read: if true; allow write: if isAdminRole(); }
    match /institucional/{file}    { allow read: if true; allow write: if isAdminRole(); }
    match /documentos/{file}       { allow read: if true; allow write: if isAdminRole(); }
    match /resultados/{file}       { allow read: if true; allow write: if isAdminRole(); }
    match /parceiros/{file}        { allow read: if true; allow write: if isAdminRole(); }
    match /equipes/{file}          { allow read: if true; allow write: if isAdminRole(); }
    match /pistas/{file}           { allow read: if true; allow write: if isAdminRole(); }
    match /atletas/{file}          { allow read: if true; allow write: if isAdminRole(); }
    match /redes-sociais/{file}    { allow read: if true; allow write: if isAdminRole(); }

    // ── Dados de arbitragem — admin ou referee ──
    match /arbitros/{path=**}           { allow read: if isAuth(); allow write: if isAdminRole() || isReferee(); }
    match /anuidades/{path=**}          { allow read: if isAuth(); allow write: if isAdminRole() || isReferee(); }
    match /reembolsos/{path=**}         { allow read: if isAuth(); allow write: if isAdminRole() || isReferee(); }
    match /relatorios/{path=**}         { allow read: if isAuth(); allow write: if isAdminRole() || isReferee(); }
    match /envio-documentos/{path=**}   { allow read: if isAuth(); allow write: if isAdminRole() || isReferee(); }

    // ── Mensagens e config — admin ──
    match /mensagens/{path=**}     { allow read: if isAuth(); allow write: if isAdminRole(); }
    match /config/{path=**}        { allow read: if isAuth(); allow write: if isAdminRole(); }

    // ── Solicitações — admin ou organizador ──
    match /solicitacoes/{allPaths=**} {
      allow read:  if isAuth();
      allow write: if isAdminRole() || isOrganizer();
    }

    // ── Bloquear qualquer outra pasta ──
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
